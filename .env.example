# Django Backend
# Generate a strong secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-strong-random-secret-key

# Set to False in production
DJANGO_DEBUG=False

# Set True to disable host header validation (recommended while stabilizing proxy routing)
DJANGO_ALLOW_ALL_HOSTS=True

# Comma-separated list of allowed hostnames (domain only, no scheme)
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Comma-separated trusted origins for CSRF checks (must include scheme)
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Comma-separated list of frontend origins allowed to call the API
# Only needed if frontend and backend are on different origins
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Seed deterministic integration data on startup
SEED_INTEGRATION_DATA=False

# When True, reset seed user data before re-seeding
SEED_INTEGRATION_DATA_RESET=False

# Port to expose the frontend on the host machine
FRONTEND_PORT=5173
